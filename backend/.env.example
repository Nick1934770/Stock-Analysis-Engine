# Copy this to .env and fill in values

# NewsAPI key (optional — falls back to Yahoo Finance RSS)
NEWS_API_KEY=your_newsapi_key_here

# Cache TTL in seconds (default: 600 = 10 minutes)
CACHE_TTL=600

# Comma-separated CORS allowed origins (include your Vercel domain for prod)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app
